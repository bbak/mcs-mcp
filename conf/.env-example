#
# Jira Instance to connect to
#
JIRA_URL=https://your-domain.atlassian.net

#
# AUTH Settings: 3 Options
#
# Use either:
# - pat (Personal Access Token) are solely used in Datacenter/Server products
# - api (API Token) are solely used in Atlassian Cloud products
JIRA_TOKEN_TYPE=api
# Set the Token
JIRA_TOKEN=
# This is just needed if JIRA_TOKEN_TYPE=api and needs to be your Jira Account E-Mail
JIRA_USER_EMAIL=
#
# 3rd Option: Session Cookies
# JIRA_XSRF_TOKEN=
# JIRA_SESSION_ID=
# JIRA_REMEMBERME_COOKIE=
# These two are optional Cookies for a Google Cloud Load Balancer
# JIRA_GCILB=
# JIRA_GCLB=

#
# Enforced delay for Requests to the JIRA REST API
#
JIRA_REQUEST_DELAY_SECONDS=5

#
# Verbosity: setting it to true writes way more data to the logfile
#
VERBOSE=false

# Optional base folder for logs and cache
# If empty or unset, defaults to the path of the binary.
# DATA_PATH=

# Reset the clock when an item backflows past the commitment point.
# Applies to both Cycle Time and WIP Age to keep them in sync.
# When true (default), backflowed items have their age recalculated
# from the last backflow date forward.
# Set to false to keep cumulative age without reset.
COMMITMENT_POINT_BACKFLOW_RESET_CLOCK=true

# Simulation engine selection: "crude" (default), "bbak" (regime-aware sampling), or "auto"
# (backtest-driven selection). See docs/architecture.md sections 4.6-4.8 for details.
# MCS_ENGINE=crude

# Per-engine weights (0 = disabled, 1-100 = enabled with tiebreak priority).
# Used by "auto" mode to break ties when two engines have identical backtest accuracy.
# MCS_ENGINE_CRUDE=50
# MCS_ENGINE_BBAK=40

# Chart rendering buffer size (most recent tool results kept for on-demand rendering).
# Absent or 0 = disabled (no HTTP server). 1-100 = enabled. Values > 100 are rejected at startup.
MCS_CHARTS_BUFFER_SIZE=20

# Initial Jira hydration window (months). The hydration JQL fetches all issues
# updated within INGESTION_UPDATED_LOOKBACK months OR created within
# INGESTION_CREATED_LOOKBACK months. The created clause keeps long-lived items
# whose last update fell outside the updated window.
INGESTION_UPDATED_LOOKBACK=24
INGESTION_CREATED_LOOKBACK=36

# Hard ceiling on items pulled during initial hydration. Paging stops once
# the running total reaches this value. Forward catch-up (import_history_update)
# is not subject to this cap.
INGESTION_MAX_ITEMS=5000
